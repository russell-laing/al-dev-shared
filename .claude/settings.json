{
  "permissions": {
    "allow": [
      "Bash",
      "Write"
    ]
  },
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/russelllaing/al-dev-shared/.claude/hooks/post_edit_validate.py"
          }
        ]
      },
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/russelllaing/al-dev-shared/.claude/hooks/post_edit_markdownlint.py"
          }
        ]
      },
      {
        "matcher": "Bash(git commit.*)",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/russelllaing/al-dev-shared/scripts/sync_history_shard.py 2>&1 | tail -5"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/russelllaing/al-dev-shared/.claude/hooks/stop_projection_check.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash(git commit.*)",
        "hooks": [
          {
            "type": "command",
            "command": "markdownlint --config .markdownlint.json profile-al-dev-shared/**/*.md .claude/skills/**/*.md 2>&1 | head -20; echo \"markdownlint preview complete (hard gate is in pre-commit hook)\""
          }
        ]
      }
    ]
  }
}

{
  "enabledPlugins": {
    "superpowers@claude-plugins-official": true
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/russelllaing/al-dev-shared/.claude/hooks/post_edit_validate.py"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 /Users/russelllaing/al-dev-shared/.claude/hooks/stop_projection_check.py"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash(git commit.*)",
        "command": "al-compile --output .dev/compile-errors.log && markdownlint profile-al-dev-shared/**/*.md .claude/skills/**/*.md 2>&1 | head -10 && echo \"Verification passed\""
      }
    ]
  }
}

#!/usr/bin/env bash
# Harness-neutrality pre-commit gate. Blocks commits that break neutrality,
# lens-policy sync, or leave generated projections stale.
# Bypass (use sparingly): git commit --no-verify
set -euo pipefail

cd "$(git rev-parse --show-toplevel)"

echo "pre-commit: validating harness neutrality..."
python3 scripts/validate_harness_neutrality.py profile-al-dev-shared

echo "pre-commit: validating lens agents (incl. lens-policy sync)..."
python3 scripts/validate_lens_agents.py

echo "pre-commit: checking projections are current..."
tmp="$(mktemp -d)"
trap 'rm -rf "$tmp"' EXIT
python3 scripts/generate_agent_projections.py --output-root "$tmp" >/dev/null
if ! diff -r --exclude="README.md" "$tmp" profile-al-dev-shared/generated/agents >/dev/null 2>&1; then
  echo "ERROR: generated projections are stale." >&2
  echo "  Run: python3 scripts/generate_agent_projections.py" >&2
  echo "  then stage profile-al-dev-shared/generated/ and commit again." >&2
  exit 1
fi

echo "pre-commit: checking staged agents/ and skills/ for markdown violations..."
staged_md=()
while IFS= read -r line; do
  [[ -n "$line" ]] && staged_md+=("$line")
done < <(git diff --cached --name-only --diff-filter=ACM \
  | grep -E '^profile-al-dev-shared/(agents|skills)/.*\.md$' || true)
if [ ${#staged_md[@]} -gt 0 ]; then
  if ! markdownlint --config .markdownlint.json "${staged_md[@]}" 2>&1; then
    echo "ERROR: markdownlint violations in staged files above." >&2
    echo "  Fix violations and re-stage before committing." >&2
    echo "  Tip: markdownlint --config .markdownlint.json <file>" >&2
    exit 1
  fi
  echo "pre-commit: markdownlint: OK (${#staged_md[@]} file(s) checked)"
fi

echo "pre-commit: checking doc-map freshness..."
stale_files=$(git diff --cached --name-only --diff-filter=ACM \
  | grep -E '^profile-al-dev-shared/(skills|agents)/' || true)
staged_maps=$(git diff --cached --name-only \
  | grep -E 'docs/(skills|agent)_map\.md' || true)
if [ -n "$stale_files" ] && [ -z "$staged_maps" ]; then
  echo "WARN: skill/agent files staged but doc maps not updated." >&2
  echo "  Run /sync-map-documentation after this commit." >&2
  echo "  Staged: $stale_files" >&2
fi
echo "pre-commit: doc-map check complete"

echo "pre-commit: checking disposition-ledger write-back..."
python3 scripts/check_ledger_staleness.py --staged \
  || echo "WARN: ledger staleness check failed to run (non-blocking)" >&2
echo "pre-commit: ledger check complete"

echo "pre-commit: checking disposition-ledger path drift..."
python3 scripts/check_ledger_path_drift.py
echo "pre-commit: ledger path-drift check complete"

echo "pre-commit: checking disposition store-vs-view drift..."
staged_ledger=$(git diff --cached --name-only --diff-filter=ACM \
  | grep -E '^docs/health/dispositions' || true)
if [ -n "$staged_ledger" ]; then
  # Only when ledger files are staged: the generated views must match the JSONL
  # store. Catches a commit that edited a view by hand or staged events without
  # running `regenerate` (the drift class path-drift and store-consistency miss).
  if ! python3 scripts/check_view_drift.py; then
    echo "ERROR: generated disposition views are out of sync with the JSONL store." >&2
    echo "  Run: python3 scripts/health_disposition_store.py regenerate" >&2
    echo "  then stage docs/health/ and commit again." >&2
    exit 1
  fi
  echo "pre-commit: store-vs-view drift check complete (views match store)"
else
  echo "pre-commit: store-vs-view drift check skipped (no staged ledger changes)"
fi

echo "pre-commit: scanning staged surface markdown for broken ledger references..."
staged_ref_md=()
while IFS= read -r line; do
  [[ -n "$line" ]] && staged_ref_md+=("$line")
done < <(git diff --cached --name-only --diff-filter=ACM \
  | grep -E '^(\.claude|profile-al-dev-shared)/.*\.md$' || true)
if [ ${#staged_ref_md[@]} -gt 0 ]; then
  ref_issues=0
  for f in "${staged_ref_md[@]}"; do
    [ -f "$f" ] || continue
    # Scoped to disposition-ledger references only — the corruption class this
    # gate protects. The broader documentation-reference backlog is out of
    # scope here; use /audit-disposition-ledger for a full ledger sweep.
    if ! python3 scripts/validate_reference_integrity.py --path "$f" --match dispositions >/dev/null 2>&1; then
      python3 scripts/validate_reference_integrity.py --path "$f" --match dispositions >&2 || true
      ref_issues=$((ref_issues + 1))
    fi
  done
  if [ "$ref_issues" -gt 0 ]; then
    echo "WARN: ${ref_issues} staged file(s) reference a renamed/deleted ledger view (non-blocking)." >&2
    echo "  Fix the paths above (underscore spelling) before they silently disable a gate." >&2
  fi
fi
echo "pre-commit: ledger reference scan complete"

echo "pre-commit: validating health-loop state breadcrumb..."
python3 scripts/validate_health_loop_state.py --staged

echo "pre-commit: validating maintainer-contract coverage..."
python3 scripts/validate_maintainer_contracts.py

echo "pre-commit: checking for staged temporary artifacts..."
python3 scripts/validate_artifact_leaks.py
echo "pre-commit: artifact leak check passed"

echo "pre-commit: all neutrality checks passed."
